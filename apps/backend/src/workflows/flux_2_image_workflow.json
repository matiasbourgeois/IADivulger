{
  "1": {
    "_meta": { "title": "UNETLoader — FLUX 2 Klein 4B" },
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "flux-2-klein-4b.safetensors",
      "weight_dtype": "default"
    }
  },
  "2": {
    "_meta": { "title": "CLIPLoader — Qwen 3 4B (FLUX 2 text encoder)" },
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "qwen_3_4b.safetensors",
      "type": "flux2",
      "device": "default"
    }
  },
  "3": {
    "_meta": { "title": "CLIPTextEncode POSITIVE — inject image_prompt here" },
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["2", 0],
      "text": "[PROMPT]"
    }
  },
  "4": {
    "_meta": { "title": "CLIPTextEncode NEGATIVE" },
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["2", 0],
      "text": "blurry, low quality, distorted, watermark, text, worst quality, JPEG artifacts, cartoon, anime, illustration, CGI, 3D render, painting, drawing"
    }
  },
  "5": {
    "_meta": { "title": "VAELoader — FLUX 2 VAE" },
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "flux2-vae.safetensors"
    }
  },
  "6": {
    "_meta": { "title": "EmptyFlux2LatentImage — 832x480 (Wan I2V resolution)" },
    "class_type": "EmptyFlux2LatentImage",
    "inputs": {
      "width": 832,
      "height": 480,
      "batch_size": 1
    }
  },
  "7": {
    "_meta": { "title": "CFGGuider — cfg=5.0" },
    "class_type": "CFGGuider",
    "inputs": {
      "model": ["1", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "cfg": 5.0
    }
  },
  "8": {
    "_meta": { "title": "KSamplerSelect — euler" },
    "class_type": "KSamplerSelect",
    "inputs": {
      "sampler_name": "euler"
    }
  },
  "9": {
    "_meta": { "title": "Flux2Scheduler — 20 steps" },
    "class_type": "Flux2Scheduler",
    "inputs": {
      "steps": 20,
      "width": 832,
      "height": 480
    }
  },
  "10": {
    "_meta": { "title": "RandomNoise" },
    "class_type": "RandomNoise",
    "inputs": {
      "noise_seed": 0
    }
  },
  "11": {
    "_meta": { "title": "SamplerCustomAdvanced" },
    "class_type": "SamplerCustomAdvanced",
    "inputs": {
      "noise": ["10", 0],
      "guider": ["7", 0],
      "sampler": ["8", 0],
      "sigmas": ["9", 0],
      "latent_image": ["6", 0]
    }
  },
  "12": {
    "_meta": { "title": "VAEDecode — latent to image" },
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["11", 0],
      "vae": ["5", 0]
    }
  },
  "13": {
    "_meta": { "title": "SaveImage — output PNG" },
    "class_type": "SaveImage",
    "inputs": {
      "images": ["12", 0],
      "filename_prefix": "IADivulger_FLUX"
    }
  }
}
