{
  "1": {
    "inputs": {
      "model": "wan2.2_t2v_high_noise_14B_fp8_scaled.safetensors",
      "load_device": "main_device",
      "base_precision": "bf16",
      "quantization": "disabled"
    },
    "class_type": "WanVideoModelLoader",
    "_meta": { "title": "Load Wan 2.2 14B Model" }
  },
  "2": {
    "inputs": {
      "model_name": "Wan2.1_VAE.pth",
      "precision": "bf16"
    },
    "class_type": "WanVideoVAELoader", 
    "_meta": { "title": "Load Wan 2.2 VAE" }
  },
  "3": {
    "inputs": {
      "model_name": "models_t5_umt5-xxl-enc-bf16.pth",
      "precision": "bf16",
      "quantization": "fp8_e4m3fn"
    },
    "class_type": "LoadWanVideoT5TextEncoder",
    "_meta": { "title": "Load UMT5 Text Encoder" }
  },
  "4": {
    "inputs": {
      "positive_prompt": "A cinematic video of [PROMPT], 4k, masterpiece, highly detailed",
      "negative_prompt": "low quality, blurry, distorted, watermark",
      "t5": ["3", 0]
    },
    "class_type": "WanVideoTextEncode",
    "_meta": { "title": "Encode Prompts" }
  },
  "6": {
    "inputs": {
      "seed": 42,
      "steps": 3,
      "cfg": 6.0,
      "shift": 5.0,
      "force_offload": "disabled",
      "riflex_freq_index": 0,
      "scheduler": "unipc",
      "model": ["1", 0],
      "image_embeds": ["9", 0],
      "text_embeds": ["4", 0]
    },
    "class_type": "WanVideoSampler",
    "_meta": { "title": "Wan Sampler (TEST: 3 steps)" }
  },
  "7": {
    "inputs": {
      "samples": ["6", 0],
      "vae": ["2", 0],
      "enable_vae_tiling": true,
      "tile_x": 272,
      "tile_y": 272,
      "tile_stride_x": 144,
      "tile_stride_y": 128
    },
    "class_type": "WanVideoDecode",
    "_meta": { "title": "Wan VAE Decode" }
  },
  "8": {
    "inputs": {
      "images": ["7", 0],
      "filename_prefix": "IADivulger_TEST",
      "frame_rate": 16,
      "format": "video/nvenc_h264-mp4",
      "loop_count": 0,
      "pingpong": false,
      "save_output": true,
      "bitrate": 12,
      "megabit": true,
      "save_metadata": true
    },
    "class_type": "VHS_VideoCombine",
    "_meta": { "title": "Save Video" }
  },
  "9": {
    "inputs": {
      "width": 832,
      "height": 480,
      "num_frames": 9
    },
    "class_type": "WanVideoEmptyEmbeds",
    "_meta": { "title": "Empty Embeds (TEST: 9 frames = ~0.5s)" }
  }
}
